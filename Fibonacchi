#FIBO USING RECUrssion
def fibo(n):
    if n <= 1:
        return 1
    else:
        return fibo(n -1) + fibo(n - 2)
        
n = int(input("Enter num: "))
for i in range(n):
    print(fibo(i),end = "   ")
    
    
